# Environment variables consumed by accounting_parser (self-hosted fork).
#
# Copy to .env and fill in real values. Never commit .env.
# The installer (P3.1) produces a sealed version of these values in
# /var/lib/accounting-parser/secrets/ with the firm master passphrase.

# ---- Database ---------------------------------------------------------
ACCOUNTING_PARSER_DB_URL=postgresql+psycopg://app_user:app_user@localhost:5432/accounting_parser

# ---- Auth adapter selection ------------------------------------------
# One of: authentik | cognito | memory
# - 'authentik' — self-hosted default (this fork)
# - 'cognito'   — cloud-variant stub; refuses to start (by design)
# - 'memory'    — in-process; tests only
ACCOUNTING_PARSER_AUTH_ADAPTER=authentik

# ---- Authentik adapter ------------------------------------------------
ACCOUNTING_PARSER_AUTHENTIK_BASE_URL=http://authentik-server:9000
ACCOUNTING_PARSER_AUTHENTIK_CLIENT_ID=accounting-parser
# API token for the Authentik management API. Created by the installer.
ACCOUNTING_PARSER_AUTHENTIK_API_TOKEN=replace-with-real-token
ACCOUNTING_PARSER_AUTHENTIK_JWKS_URL=http://authentik-server:9000/application/o/accounting-parser/jwks/
ACCOUNTING_PARSER_AUTHENTIK_AUDIENCE=accounting-parser
ACCOUNTING_PARSER_AUTHENTIK_ISSUER=http://authentik-server:9000/application/o/accounting-parser/

# ---- Session signing --------------------------------------------------
# PEM-encoded RSA-2048 private key. Generated by the installer. Paste
# the whole block between the literal -----BEGIN/END lines.
# In a .env file use the \n form and quotes; in systemd env files use
# a single-line PEM or mount a secret file and use the ENV_FILE pattern.
ACCOUNTING_PARSER_SESSION_SIGNING_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
ACCOUNTING_PARSER_SESSION_SIGNING_KID=session-signing-v1
ACCOUNTING_PARSER_SESSION_DURATION_SECONDS=86400

# ---- Magic link -------------------------------------------------------
ACCOUNTING_PARSER_MAGIC_LINK_TTL_SECONDS=900

# ---- Firm identity (WebAuthn RP) --------------------------------------
ACCOUNTING_PARSER_FIRM_RP_NAME="Example CPA Firm"
# MUST match the effective domain users type in the browser. Common
# values: 'localhost' for dev, 'firmname.local' for LAN, or the FQDN
# for public deployments.
ACCOUNTING_PARSER_FIRM_RP_ID=localhost

# ---- Document storage -------------------------------------------------
# One of: minio | s3 | memory
# - 'minio'  — self-hosted default (MinIO running in the compose stack)
# - 's3'     — cloud-variant stub; refuses to start
# - 'memory' — in-process; tests only
ACCOUNTING_PARSER_DOC_STORE_ADAPTER=minio
ACCOUNTING_PARSER_MINIO_ENDPOINT_URL=http://minio:9000
ACCOUNTING_PARSER_MINIO_ACCESS_KEY=minio
ACCOUNTING_PARSER_MINIO_SECRET_KEY=minio-dev-only
ACCOUNTING_PARSER_MINIO_REGION=us-east-1
ACCOUNTING_PARSER_STORAGE_BUCKET=accounting-parser

# ---- Ingestion --------------------------------------------------------
ACCOUNTING_PARSER_INGEST_MAX_BYTES=104857600   # 100 MiB
# One of: clamd | null (null skips scanning; use with extreme care)
ACCOUNTING_PARSER_VIRUS_SCANNER=clamd
ACCOUNTING_PARSER_CLAMD_HOST=clamav
ACCOUNTING_PARSER_CLAMD_PORT=3310
